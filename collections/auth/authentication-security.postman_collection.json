          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid.token.value"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
