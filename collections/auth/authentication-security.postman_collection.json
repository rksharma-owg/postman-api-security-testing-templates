            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Safe defensive test template. Run only against systems you own or are authorized to assess.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{used_refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
